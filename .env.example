# Copy this file to .env and adjust values before running `docker compose up`.

POSTGRES_DB=ExpenseTracking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Generate a real secret for anything beyond local dev, e.g.: openssl rand -base64 32
JWT_SECRET=dGhpcy1pcy1hLWRldi1vbmx5LXNlY3JldC1rZXktY2hhbmdlLWluLXByb2R1Y3Rpb24tcGxlYXNlfg==

# Only matters if you also run the Vite dev server (npm run dev) against this
# backend instead of using the bundled frontend served at http://localhost:8080/.
CORS_ALLOWED_ORIGIN=http://localhost:5173

# "console" logs the signup/reset OTP to the backend log instead of emailing it -
# no SMTP account needed for local dev. Switch to "smtp" once the SMTP_* values
# below are real (Gmail needs an App Password, not the account's login password:
# Google Account -> Security -> 2-Step Verification -> App Passwords).
OTP_MODE=console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
